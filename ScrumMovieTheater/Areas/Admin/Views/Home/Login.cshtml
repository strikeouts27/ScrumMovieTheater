@{
    ViewData["Title"] = "Manager Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Login.css" asp-append-version="true" />
}

<div class="login-wrapper d-flex align-items-center justify-content-center">
    <div class="card bg-dark text-white shadow border-danger login-card">
        <div class="card-header login-header text-center">
            <h2 class="fw-bold mb-0">Manager Portal</h2>
            <p class="mb-0 small">Scrum Movie Theater</p>
        </div>
        <div class="card-body p-4">
            <form asp-area="Admin" asp-controller="Home" asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <input type="text" name="username" class="form-control bg-dark text-white border-secondary" placeholder="Enter username" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input type="password" name="password" class="form-control bg-dark text-white border-secondary" placeholder="Enter password" required />
                </div>
                <button type="submit" class="btn login-btn w-100 mt-2">Login</button>
            </form>
        </div>
    </div>
</div>