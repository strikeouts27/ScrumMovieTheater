@model ScrumMovieTheater.Models.MovieViewModel

@{
    ViewData["Title"] = "DeleteMovie";
}

@section Styles {
    <link rel="stylesheet" href="~/css/MovieForm.css" asp-append-version="true" />
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Delete Movie</title>

    
</head>
<body>

    <div class="container">

        <div class="header">
            <h1>Delete Movie</h1>
        </div>

        <div class="form">

            <label for="movieId">Movie ID</label>

            <input
                type="number"
                id="movieId"
                placeholder="Enter Movie ID">

            <button class="delete-btn">
                Delete Movie
            </button>

            <button
                class="home-btn"
                onclick="window.location.href='Manager.html'">
                Return Home
            </button>

        </div>

    </div>

</body>
</html>