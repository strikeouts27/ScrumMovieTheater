@model ScrumMovieTheater.Models.MovieViewModel

@{
    ViewData["Title"] = "DeleteMovie";
}

<!DOCTYPE html>
<html>
<head>
    <title>Delete Movie</title>

    <style>
        .movie-form {
            display: flex;
            flex-direction: column;
            background-color: teal;
        }

        .movie-form label {
            margin-top: 10px;
            font-weight: bold;
        }

        .movie-form input,
        .movie-form select,
        .movie-form textarea {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border: 1px solid #ccc;
            border-radius: 5px;
        }

        .movie-form textarea {
            resize: vertical;
        }

        .add-btn {
            margin-top: 20px;
            background-color: green;
            color: white;
            padding: 12px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }

        .add-btn:hover {
            background-color: darkgreen;
        }

        .delete-btn {
            background-color: red;
            color: white;
            padding: 12px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            margin-top: 20px;
        }

        .delete-btn:hover {
            background-color: darkred;
        }
    </style>

</head>

<body>

<div class="movie-form">

    <h2>Delete Movie</h2>

    <label for="movieId">Movie ID</label>
    <input type="number" id="movieId" placeholder="Enter Movie ID">

    <button class="delete-btn">Delete Movie</button>
    <a href="/" class="home" style="color: white;">Return Home</a>

</div>

</body>
</html>