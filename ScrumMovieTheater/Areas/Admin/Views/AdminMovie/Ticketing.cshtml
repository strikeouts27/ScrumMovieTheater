@{
    ViewData["Title"] = "Ticketing";
}
@section Scripts {
    

    <script>
    const ticketInput = document.getElementById("tickets");
    const totalSpan = document.getElementById("total");
    const pricePerTicket = 10;

    ticketInput.addEventListener("input", function () {
        let qty = parseInt(ticketInput.value) || 0;
        totalSpan.textContent = qty * pricePerTicket;
    });
</script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/Ticketing.css" asp-append-version="true" />
}


<div class="ticket-container">

    <h2>🎟️ Book Your Ticket</h2>

    <form method="post">

        <label>Movie Name</label>
        <select name="movie">
            <option>Avengers</option>
            <option>Batman</option>
            <option>Spider-Man</option>
        </select>

        <label>Full Name</label>
        <input type="text" name="name" required />

        <label>Phone Number (for confirmation)</label>
        <input type="tel" name="phone" placeholder="e.g. 214-555-1234" required />

        <label>Email</label>
        <input type="email" name="email" required />

        <label>Number of Tickets</label>
        <input type="number" name="tickets" id="tickets" min="1" max="10" value="1" required />

        <p class="total">
            💰 Price per ticket: $10 <br />
            Total: $<span id="total">10</span>
        </p>

        <button type="submit" class="btn">Book Ticket</button>

    </form>

    <a href="/" class="home">⬅ Return Home</a>

</div>

