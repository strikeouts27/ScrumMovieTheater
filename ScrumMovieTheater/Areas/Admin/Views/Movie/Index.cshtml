@model List<ScrumMovieTheater.Models.Movie>
<style>
    body {
        background-color: #000000;
        color: white;
    }

    h2 {
        color: white;
    }

    table {
        color: white !important;
        background-color: #000000;
        border-radius: 10px;
        overflow: hidden;
    }

    .table th {
        background-color: #000000;
        color: white;
    }

    .table td {
        background-color: #000000;
        color: white;
        border-color: #334155;
    }

    .alert-success {
        background-color: #14532d;
        color: white;
        border: none;
    }

    .btn-primary {
        background-color: #2563eb;
        border-color: #2563eb;
    }

    .btn-danger {
        background-color: #dc2626;
        border-color: #dc2626;
    }
</style>


<h2>Movies List</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<table class="table">
<tr>
    <th>Title</th>
    <th>Actions</th>
</tr>



@foreach (var movie in Model)
{
    <tr>
        <td>@movie.Title</td>

        <td>
            <a asp-area="Admin"
               asp-controller="Movie"
               asp-action="EditMovie"
               asp-route-id="@movie.MovieId"
               class="btn btn-primary">
               Edit
            </a>
       <a asp-area="Admin"
       asp-controller="Movie"
       asp-action="DeleteMovie"
       asp-route-id="@movie.MovieId"
       class="btn btn-danger"
       onclick="return confirm('Are you sure you want to delete this movie?');">
       Delete
       </a>
       </td>
    </tr>
}
</table>