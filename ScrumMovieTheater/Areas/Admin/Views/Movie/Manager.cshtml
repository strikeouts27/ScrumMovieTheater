@{
    ViewData["Title"] = "Manager View";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/ManagerAddMovie.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<div class="container py-4">

    <h1 class="fw-bold mb-4 manager-title">Movie Theater Manager</h1>

    <!-- Add Movie Form -->
    <div class="container py-4 py-lg-5">
        <div class="row justify-content-center">
            <div class="col-12 col-xl-8">
                <div class="card border-0 shadow-sm bg-dark text-white">
                    <div class="card-header manager-card-header py-3">
                        <h1 class="h5 mb-0">Add New Movie</h1>
                    </div>
                    <div class="card-body p-4">
                        <form asp-area="Admin" asp-controller="Movie" asp-action="AddMovie" method="post" novalidate>
                            @Html.AntiForgeryToken()

                            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                            <div class="mb-3">
                                <label class="form-label">Title</label>
                                <input name="Title" class="form-control bg-dark text-white border-secondary" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <textarea name="Description" class="form-control bg-dark text-white border-secondary" rows="4"></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Genre</label>
                                <select name="Genre" class="form-select bg-dark text-white border-secondary">
                                    <option value="">Choose a genre</option>
                                    <option>Action</option>
                                    <option>Comedy</option>
                                    <option>Drama</option>
                                    <option>Horror</option>
                                </select>
                            </div>

                            <div class="row g-3 mb-3">
                                <div class="mb-3">
                                    <label for="movieDuration" class="form-label">Movie Duration</label>
                                    <div class="input-group">
                                        <input type="number"
                                               class="form-control bg-dark text-white border-secondary"
                                               id="movieDuration"
                                               name="DurationInMinutes"
                                               min="1"
                                               max="600"
                                               placeholder="e.g., 165"
                                               required>
                                        <span class="input-group-text bg-dark text-white border-secondary" id="duration-addon">minutes</span>
                                    </div>
                                    <div class="form-text text-muted">Enter the total duration entirely in minutes (e.g., 2h 45m is 165 minutes).</div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-2">
                                <button type="reset" class="btn btn-outline-secondary">Clear</button>
                                <button type="submit" class="btn manager-add-btn">Save Movie</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Current Movies Table -->
    <div class="card bg-dark text-white border-danger shadow">
        <div class="card-header manager-card-header">
            <h2 class="h5 mb-0">Current Movies</h2>
        </div>
        <div class="card-body p-0">
            <table class="table table-dark table-hover table-bordered mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Title</th>
                        <th>Description</th>
                        <th>Release Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>1</td>
                        <td class="fw-bold">John Wick</td>
                        <td>An ex-hitman comes out of retirement.</td>
                        <td>10/24/2014</td>
                        <td>
                            <a href="/Admin/Movie/EditMovie/1" class="btn btn-sm manager-edit-btn me-1">Edit</a>
                            <button class="btn btn-sm manager-delete-btn" onclick="return confirm('Are you sure?')">Delete</button>
                        </td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td class="fw-bold">Interstellar</td>
                        <td>A team of explorers travel through a wormhole.</td>
                        <td>11/07/2014</td>
                        <td>
                            <a href="/Admin/Movie/EditMovie/1" class="btn btn-sm manager-edit-btn me-1">Edit</a>
                            <button class="btn btn-sm manager-delete-btn" onclick="return confirm('Are you sure?')">Delete</button>
                        </td>
                    </tr>
                    <tr>
                        <td>3</td>
                        <td class="fw-bold">The Godfather</td>
                        <td>The aging patriarch of an organized crime dynasty.</td>
                        <td>03/24/1972</td>
                        <td>
                            <a href="/Admin/Movie/EditMovie/1" class="btn btn-sm manager-edit-btn me-1">Edit</a>
                            <button class="btn btn-sm manager-delete-btn" onclick="return confirm('Are you sure?')">Delete</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

</div>