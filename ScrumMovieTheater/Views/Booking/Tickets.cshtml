@{
    ViewData["Title"] = "Tickets";
}

<h2>Book Tickets</h2>

   
@if (ViewBag.Movie != null)
{
    <div class="alert alert-info">
        <strong>Selected Movie:</strong> @ViewBag.Movie <br />
        <strong>Time:</strong> @ViewBag.Time
    </div>
}
else
{
    <div class="alert alert-warning">
        Please select a movie and time from Showtimes page.

        <a class="btn btn-outline-primary" asp-controller="Showtimes" asp-action="Index">
              Select Movie / Showtimes
        </a>

    </div>
}

<form method="post" action="/Booking/Confirm">

    <input type="hidden" name="scheduleId" value="@ViewBag.ScheduleId" />

    <div class="mb-3">
        <label>Your Name</label>
        <input type="text" name="customerName" class="form-control" required />
    </div>

    <div class="mb-3">
        <label>Adults ($10)</label>
        <input type="number" name="adults" value="0" min="0" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Kids ($5)</label>
        <input type="number" name="kids" value="0" min="0" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">
        Confirm Booking
    </button>

</form>