@model ScrumMovieTheater.Models.Movie
<style>
body {
    background-color: #000000  !important;
    color: white;
}

table {
    background-color: #1e293b !important;
    color: white;
}

thead {
    background-color: #000000  !important;
    color: #facc15;
}

tbody tr {
    background-color: #000000  !important;
    color: white;
}

tbody tr:nth-child(even) {
    background-color: #111827 !important;
}
</style>

<div style="max-width:800px; margin:auto;">

    <h2>@Model.Title</h2>

    <img src="@Model.ImageUrl"
         style="width:200px; height:300px; object-fit:cover; border-radius:8px;" />

    <p><b>Description:</b> @Model.Description</p>
    <p><b>Genre:</b> @Model.Genre</p>
    <p><b>Rating:</b> @Model.Rating</p>
    <p><b>Runtime:</b> @Model.RuntimeMinutes minutes</p>
    <p><b>Release Date:</b> @Model.ReleaseDate</p>

</div>