@model IReadOnlyList<ScrumMovieTheater.Models.MovieViewModel>

@{
    ViewData["Title"] = "Movies";
}

<div class="container py-4 py-lg-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-2 mb-4">
        <div>
            <h1 class="display-6 mb-1">Movies</h1>
            <p class="text-muted mb-0">Current movies available on the website.</p>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info border-0 shadow-sm mb-0" role="alert">
            No movies have been added yet.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @foreach (var movie in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <h2 class="h5 card-title mb-0">@movie.Title</h2>
                                <span class="badge text-bg-primary">@((int)movie.Duration.TotalMinutes) min</span>
                            </div>
                            <p class="text-muted mb-2">@movie.Genre</p>
                            <p class="card-text flex-grow-1">@movie.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
